---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title?: string;
}

const { title = "Sceno Ichiro ｜ website" } = Astro.props;
---

<!doctype html>
<html lang="ja">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/png" href="/favicon.png" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
		
		<link rel="stylesheet" href="/assets/style.css">
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Jost:ital@0;1&family=Zen+Kaku+Gothic+New&display=swap" rel="stylesheet">
	</head>
	<body>
		<Header />
		<slot />
		<Footer />
		
		<!-- 左下固定アイコン -->
		<img src="/assets/portrait.png" alt="Sceno Ichiro" class="fixed-logo-icon" />

		<script>
		  // JS実行開始を通知（チラつき防止）
		  document.body.classList.add('js-ready');

		  // スクロールインジケーター：クリックでコンテンツ開始位置へスクロール
		  const scrollIndicator = document.getElementById('scroll-indicator');
		  const contentStart = document.getElementById('content-start');
		  const header = document.querySelector('.header-menu');
		  
		  if (scrollIndicator && contentStart) {
		    scrollIndicator.addEventListener('click', () => {
		      const headerHeight = header ? header.offsetHeight : 0;
		      const targetPosition = contentStart.offsetTop - headerHeight;
		      
		      // スムーススクロールを手動実装（速度調整のため）
		      const startPosition = window.scrollY;
		      const distance = targetPosition - startPosition;
		      const duration = 1200; // 1.2秒（デフォルトより遅め）
		      let startTime = null;
		      
		      function animation(currentTime) {
		        if (startTime === null) startTime = currentTime;
		        const timeElapsed = currentTime - startTime;
		        const progress = Math.min(timeElapsed / duration, 1);
		        
		        // イージング関数（ease-in-out）
		        const ease = progress < 0.5
		          ? 2 * progress * progress
		          : 1 - Math.pow(-2 * progress + 2, 2) / 2;
		        
		        window.scrollTo(0, startPosition + distance * ease);
		        
		        if (timeElapsed < duration) {
		          requestAnimationFrame(animation);
		        }
		      }
		      
		      requestAnimationFrame(animation);
		    });
		  }

		  // 右下アイコン：ページ末尾近くで表示、クリックでトップへ
		  const fixedIcon = document.querySelector('.fixed-logo-icon');
		  if (fixedIcon) {
		    window.addEventListener('scroll', () => {
		      const scrolledToBottom = window.innerHeight + window.scrollY >= document.body.offsetHeight - 500;
		      fixedIcon.classList.toggle('visible', scrolledToBottom);
		    });
		    fixedIcon.addEventListener('click', () => {
		      window.scrollTo({ top: 0, behavior: 'smooth' });
		    });
		  }

		  // スクロールアニメーション
		  const observer = new IntersectionObserver((entries) => {
		    entries.forEach(entry => {
		      if (entry.isIntersecting) {
		        entry.target.classList.add('visible');
		        observer.unobserve(entry.target);
		      }
		    });
		  }, { threshold: 0.01, rootMargin: '0px 0px 0px 0px' });

		  // 明示的に .reveal クラスがついている要素
		  document.querySelectorAll('.reveal').forEach(el => observer.observe(el));

		  // main直下の要素も自動でreveal対象に（h1, h2, p, section, article, .card など）
		  document.querySelectorAll('main > *, main h1, main h2, main p, main section, main article')
		    .forEach((el, i) => {
		      if (!el.classList.contains('reveal')) {
		        el.classList.add('reveal');
		        el.style.transitionDelay = `${i * 0.02}s`;
		        observer.observe(el);
		      }
		    });

		  // スクロール停止時に画面内の未表示要素を強制表示
		  let scrollTimeout;
		  window.addEventListener('scroll', () => {
		    clearTimeout(scrollTimeout);
		    scrollTimeout = setTimeout(() => {
		      document.querySelectorAll('.reveal:not(.visible)').forEach(el => {
		        const rect = el.getBoundingClientRect();
		        const isInViewport = rect.top < window.innerHeight && rect.bottom > 0;
		        if (isInViewport) {
		          el.classList.add('visible');
		        }
		      });
		    }, 75);
		  });

		  // ページ遷移フェードアウト（mainのみ）
		  document.querySelectorAll('a[href]').forEach(link => {
		    const href = link.getAttribute('href');
		    if (!href || href.startsWith('#') || href.startsWith('http') || href.startsWith('mailto')) return;
		    link.addEventListener('click', (e) => {
		      e.preventDefault();
		      const main = document.querySelector('main');
		      if (main) main.classList.add('page-leaving');
		      setTimeout(() => { window.location.href = href; }, 300);
		    });
		  });
		</script>
	</body>
</html>
